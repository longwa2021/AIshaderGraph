{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "090400865aea45a19dce4eff49b380f1",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "StylizedHairLighting (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -400.0,
            "y": 0.0,
            "width": 150.0,
            "height": 80.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "edfe34bbbd4b47258532077803e484f3"
        },
        {
            "m_Id": "a47ece668089408ca329f18799c7d4d9"
        },
        {
            "m_Id": "c8a45d1ebd274319b9cb44f80722d043"
        },
        {
            "m_Id": "28e56a7d27404bfdba522a3805ddf515"
        },
        {
            "m_Id": "94d18bedd7ae44cd9c550be74fb4996f"
        },
        {
            "m_Id": "93aff65a1496436ea284290a7ebb5da7"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "StylizedHairLighting",
    "m_FunctionSource": "32776582d4016ca47bea50baa33f05df",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#pragma multi_compile _ _MAIN_LIGHT_SHADOWS\n#pragma multi_compile _ _MAIN_LIGHT_SHADOWS_CASCADE\n#pragma multi_compile _ _ADDITIONAL_LIGHT_SHADOWS\n\n#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid StylizedHairLighting_float(\n    float3 WorldPos,\n    float3 DiffuseLighting,\n    float3 Specular,\n    float3 Rim,\n    float3 Env,\n    out float3 OutColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    OutColor = DiffuseLighting + Specular + Rim + Env;\n    #else\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\n    Light mainLight = GetMainLight(shadowCoord);\n    float3 lightColor = mainLight.color;\n    float shadowAtten = mainLight.shadowAttenuation;\n\n    float3 diffuse = DiffuseLighting * lightColor * shadowAtten;\n    float3 specular = Specular * lightColor * shadowAtten;\n    float3 rim = Rim * lightColor;\n\n    OutColor = diffuse + specular + rim + Env;\n    #endif\n}"
}

