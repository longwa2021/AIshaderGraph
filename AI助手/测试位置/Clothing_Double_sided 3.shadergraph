    "m_FunctionBody": "#pragma multi_compile _ _MAIN_LIGHT_SHADOWS\n#pragma multi_compile _ _MAIN_LIGHT_SHADOWS_CASCADE\n#pragma multi_compile _ _ADDITIONAL_LIGHT_SHADOWS\n\n#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid UnityChanClothingLighting_float(\n    float3 WorldPos,\n    float3 WorldNormal,\n    float3 ViewDir,\n    float3 MainLightDir,\n    float3 DiffuseColor,\n    float3 ShadowColor,\n    float3 FalloffColor,\n    float3 RimColor,\n    float SpecularMask,\n    float SpecularPower,\n    float3 EnvMapColor,\n    out float3 OutColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    OutColor = DiffuseColor;\n    #else\n    // 调试开关（按需取消注释）\n    // OutColor = DiffuseColor; return;\n    // OutColor = ShadowColor; return;\n    // OutColor = FalloffColor; return;\n    // OutColor = RimColor; return;\n    // OutColor = WorldNormal * 0.5 + 0.5; return;\n\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\n    Light mainLight = GetMainLight(shadowCoord);\n    float3 lightColor = mainLight.color;\n    float shadowAtten = mainLight.shadowAttenuation;\n\n    // 原版UnityChan的Falloff逻辑：falloff值代表阴影程度（0=全亮，1=全暗）\n    float falloff = FalloffColor.r;\n    float3 baseLighting = lerp(DiffuseColor, ShadowColor, falloff);\n    float3 diffuse = baseLighting * lightColor * shadowAtten;\n\n    // 高光\n    float3 halfVec = normalize(ViewDir + MainLightDir);\n    float NdotH = saturate(dot(WorldNormal, halfVec));\n    float spec = pow(NdotH, SpecularPower) * SpecularMask;\n    float3 specular = spec * lightColor * shadowAtten;\n\n    OutColor = diffuse + specular + RimColor + EnvMapColor;\n    #endif\n}"
}

