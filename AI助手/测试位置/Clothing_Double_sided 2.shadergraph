{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "2c2804dd08cb49a7bfc294782eb8d069",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "UnityChanClothingLighting (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -188.00015258789063,
            "y": 458.6666564941406,
            "width": 308.0,
            "height": 519.9998779296875
        }
    },
    "m_Slots": [
        {
            "m_Id": "3e0873e7c4894ddb80a22dfa384d4c9d"
        },
        {
            "m_Id": "0ce7bb7fa6b043cbac8445d0ad4edd40"
        },
        {
            "m_Id": "e4e42d691de44c60b44f354d4063bed9"
        },
        {
            "m_Id": "5da8f55e736b459e821da238cdc0bfd3"
        },
        {
            "m_Id": "449ddca168cf4fed8a68b2593fbfbd6e"
        },
        {
            "m_Id": "2f643d10423447d2b328837cca6f0a0e"
        },
        {
            "m_Id": "e7e8ebe2d1ed441bb4dd33779e6a0851"
        },
        {
            "m_Id": "2ac0f3afe9af49aa89a907455137cbad"
        },
        {
            "m_Id": "f10bf0de3af94fa29298f1894f1d0345"
        },
        {
            "m_Id": "9be3d1e4b0d54cb0b52249f6e8f23947"
        },
        {
            "m_Id": "497616d67f584c9ab510e30b00c47323"
        },
        {
            "m_Id": "bfb9fc7bcd6c4407b65769ba70c9f323"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "UnityChanClothingLighting",
    "m_FunctionSource": "bba84e4d3ed944f47a7d59193c06b077",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#pragma multi_compile _ _MAIN_LIGHT_SHADOWS\n#pragma multi_compile _ _MAIN_LIGHT_SHADOWS_CASCADE\n#pragma multi_compile _ _ADDITIONAL_LIGHT_SHADOWS\n\n#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid UnityChanClothingLighting_float(\n    float3 WorldPos,\n    float3 WorldNormal,\n    float3 ViewDir,\n    float3 MainLightDir,\n    float3 DiffuseColor,\n    float3 ShadowColor,\n    float3 FalloffColor,\n    float3 RimColor,\n    float SpecularMask,\n    float SpecularPower,\n    float3 EnvMapColor,\n    out float3 OutColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    OutColor = DiffuseColor;\n    #else\n    // --- 调试开关：取消注释下面任一行可单独查看各分量 ---\n    // OutColor = DiffuseColor; return;\n    // OutColor = ShadowColor; return;\n    // OutColor = FalloffColor; return;\n    // OutColor = RimColor; return;\n    // OutColor = WorldNormal * 0.5 + 0.5; return;\n\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\n    Light mainLight = GetMainLight(shadowCoord);\n    float3 lightColor = mainLight.color;\n    float shadowAtten = mainLight.shadowAttenuation;\n\n    // 确保 falloff 值在 [0,1] 内\n    float falloff = saturate(FalloffColor.r);\n    float3 baseLighting = lerp(ShadowColor, DiffuseColor, falloff);\n    float3 diffuse = baseLighting * lightColor * shadowAtten;\n\n    float3 halfVec = normalize(ViewDir + MainLightDir);\n    float NdotH = saturate(dot(WorldNormal, halfVec));\n    float spec = pow(NdotH, SpecularPower) * SpecularMask;\n    float3 specular = spec * lightColor * shadowAtten;\n\n    OutColor = diffuse + specular + RimColor + EnvMapColor;\n    #endif\n}"
}

