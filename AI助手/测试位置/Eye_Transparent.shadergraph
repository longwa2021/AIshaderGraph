{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "9688445cee5a49b7b83000c179450066",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "UnityChanEyeLighting (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -400.0,
            "y": 0.0,
            "width": 150.0,
            "height": 80.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "fd2205100a7140bb8c4bd023f761dabd"
        },
        {
            "m_Id": "9912eacaa93d4a1da9f5a8c8d54d3045"
        },
        {
            "m_Id": "f8ade1cb84eb4399b271212c3ab2fcb1"
        },
        {
            "m_Id": "0a988213e96a432abe8f5cb7188260bc"
        },
        {
            "m_Id": "2189c9674706429cb8912fcd871c9cf0"
        },
        {
            "m_Id": "d53153d325a14b87ae94593d13723b59"
        },
        {
            "m_Id": "7b74b0bfcaf4468a874166ffcfb1a21f"
        },
        {
            "m_Id": "2ced3f0d32dc41c1a08c26e464586779"
        },
        {
            "m_Id": "be9f84a2a33e41a0beb476c266437a4a"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "UnityChanEyeLighting",
    "m_FunctionSource": "11f0ff36b9950d7458134b2c10f7c0c6",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#pragma multi_compile _ _MAIN_LIGHT_SHADOWS\n#pragma multi_compile _ _MAIN_LIGHT_SHADOWS_CASCADE\n#pragma multi_compile _ _ADDITIONAL_LIGHT_SHADOWS\n\n#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid UnityChanEyeLighting_float(\n    float3 WorldPos,\n    float3 WorldNormal,\n    float3 ViewDir,\n    float3 MainLightDir,\n    float3 DiffuseColor,\n    float3 ShadowColor,\n    float3 FalloffColor,\n    float3 RimColor,\n    out float3 OutColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    OutColor = DiffuseColor;\n    #else\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\n    Light mainLight = GetMainLight(shadowCoord);\n    float3 lightColor = mainLight.color;\n    float shadowAtten = mainLight.shadowAttenuation;\n\n    float falloff = FalloffColor.r;\n    float3 baseLighting = lerp(ShadowColor, DiffuseColor, falloff);\n    float3 lit = baseLighting * lightColor * shadowAtten;\n\n    OutColor = lit + RimColor;\n    #endif\n}"
}

