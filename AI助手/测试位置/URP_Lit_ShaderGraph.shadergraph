    },
    "m_Slots": [
        {
            "m_Id": "cedbba23dca3495999ce376d8faaccb2"
        },
        {
            "m_Id": "f7d6104ae13440449d0d0284744bf2cc"
        },
        {
            "m_Id": "ac5f326715204b94bdead6df00f92fe1"
        },
        {
            "m_Id": "7bdc08bff6244320843cde14306a4d14"
        },
        {
            "m_Id": "2b18d33d912d400ab73374bbbe42cf42"
        },
        {
            "m_Id": "ad75dfe98ae34f40850254027f437530"
        },
        {
            "m_Id": "47034fc0afd74ec6b92a93975b31207d"
        },
        {
            "m_Id": "7bf8ef395d494f61b369b4c84ab6fb91"
        },
        {
            "m_Id": "53f41d442fdc48f886354cb739929715"
        },
        {
            "m_Id": "5a78b797f6674695a78fc6801ea2205b"
        },
        {
            "m_Id": "84d1263069c648c3a46e9be08883e821"
        },
        {
            "m_Id": "f3abb66266e84d14bc03adf675b4f9e8"
        },
        {
            "m_Id": "56687193b6b44625a2e26c0102f4458d"
        },
        {
            "m_Id": "37a971ff838442ffa8da592387320c30"
        },
        {
            "m_Id": "4170074e00ad45e192f7a639f5bca403"
        },
        {
            "m_Id": "f65661a3e14241928e3fb9c506c6d531"
        },
        {
            "m_Id": "974066cab93a4ab78b0770ce8d0090a0"
        },
        {
            "m_Id": "365b8e1629cf442a8ebe64fe093b20d5"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "StockingLighting",
    "m_FunctionSource": "db44a0457298a1742a88856067ec8288",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid StockingLighting_float(\n    float3 WorldPos,\n    float3 WorldNormal,\n    float3 WorldTangent,\n    float3 ViewDir,\n    float3 LightDir,\n    float3 BaseColor,\n    float3 SkinColor,\n    float Thickness,\n    float Translucency,\n    float Wrap,\n    float SSSIntensity,\n    float AnisoGloss,\n    float AnisoIntensity,\n    float3 SpecColorShift,\n    float RimPower,\n    float RimIntensity,\n    float3 RimColor,\n    out float3 FinalColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    FinalColor = BaseColor;\n    #else\n    Light mainLight = GetMainLight(TransformWorldToShadowCoord(WorldPos));\n    float3 L = mainLight.direction;\n    float3 lightColor = mainLight.color;\n    float shadow = mainLight.shadowAttenuation;\n\n    float3 V = normalize(ViewDir);\n    float3 N = normalize(WorldNormal);\n    float3 T = normalize(WorldTangent);\n    float3 H = normalize(L + V);\n\n    // Wrapped Diffuse\n    float NdotL = dot(N, L);\n    float wrapped = saturate((NdotL + Wrap) / (1.0 + Wrap));\n    float3 nylonBase = lerp(SkinColor, BaseColor, Thickness * Translucency);\n    float3 diffuse = nylonBase * lightColor * wrapped * shadow;\n\n    // Back SSS\n    float backLight = saturate(-NdotL);\n    float3 sss = SkinColor * backLight * SSSIntensity * Thickness * lightColor;\n\n    // Anisotropic Specular (Kajiya-Kay)\n    float HdotT = dot(H, T);\n    float sinTH = sqrt(1.0 - HdotT * HdotT);\n    float specMask = pow(sinTH, AnisoGloss) * AnisoIntensity * shadow;\n    float3 specColor = BaseColor * SpecColorShift;\n    float3 specular = specMask * specColor * lightColor;\n\n    // Rim Light (Fresnel + Thickness)\n    float fresnel = 1.0 - saturate(dot(N, V));\n    float rim = pow(fresnel, RimPower) * RimIntensity * (1.0 + Thickness);\n    float3 rimLight = rim * RimColor;\n\n    FinalColor = diffuse + sss + specular + rimLight;\n    #endif\n}"
}

