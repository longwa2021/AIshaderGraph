    },
    "m_Name": "UnityChanSkinLighting (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -400.0000915527344,
            "y": -0.000001221702405018732,
            "width": 284.6667175292969,
            "height": 448.0000305175781
        }
    },
    "m_Slots": [
        {
            "m_Id": "b5eaacbdddf54395bc7b51e2430ac72c"
        },
        {
            "m_Id": "5de040b6f41e45288fece26202a5a7e4"
        },
        {
            "m_Id": "44e990e03bf54846870af200edbba592"
        },
        {
            "m_Id": "e739903c71d142bcb31e956a9227e3d3"
        },
        {
            "m_Id": "798759c114954b31a6def8b4ccaa9b5e"
        },
        {
            "m_Id": "9052a05322d84fff9d278fed444e861e"
        },
        {
            "m_Id": "4d7fa766f25d45e1bbb623dd8aae55f7"
        },
        {
            "m_Id": "9b5fad696ce34bc8b30c3872ebb3ab07"
        },
        {
            "m_Id": "3d4904aef2a5455da76173bd84379083"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "UnityChanSkinLighting",
    "m_FunctionSource": "56c9bd9c8869a9e458dc5c96fcd60b82",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid UnityChanSkinLighting_float(\n    float3 WorldPos,\n    float3 WorldNormal,\n    float3 ViewDir,\n    float3 MainLightDir,\n    float3 DiffuseColor,\n    float3 ShadowColor,\n    float3 FalloffColor,\n    float3 RimColor,\n    out float3 OutColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    OutColor = DiffuseColor;\n    #else\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\n    Light mainLight = GetMainLight(shadowCoord);\n    float3 lightColor = mainLight.color;\n    float shadowAtten = mainLight.shadowAttenuation;\n\n    float falloff = FalloffColor.r;\n    float3 baseLighting = lerp(ShadowColor, DiffuseColor, falloff);\n    float3 lit = baseLighting * lightColor * shadowAtten;\n\n    OutColor = lit + RimColor;\n    #endif\n}"
}

