    "m_FunctionSource": "69c14b1d4459e1447a22fb59bef31b6f",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid ToonLighting_float(\n    float3 WorldPos,\n    float3 WorldNormal,\n    float3 ViewDir,\n    float3 MainLightDir,\n    float3 BaseColor,\n    float3 RampColor,\n    float Roughness,\n    float AO,\n    float3 SpecularColor,\n    float SpecularSize,\n    float SpecularIntensity,\n    float RimPower,\n    float RimIntensity,\n    float3 RimColor,\n    out float3 OutColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    OutColor = BaseColor;\n    #else\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\n    Light mainLight = GetMainLight(shadowCoord);\n    float3 lightColor = mainLight.color;\n    float shadowAtten = mainLight.shadowAttenuation;\n\n    float NdotL = dot(WorldNormal, MainLightDir);\n    float halfLambert = NdotL * 0.5 + 0.5;\n    float3 diffuse = BaseColor * RampColor * lightColor * shadowAtten * AO;\n\n    float3 halfVec = normalize(ViewDir + MainLightDir);\n    float NdotH = saturate(dot(WorldNormal, halfVec));\n    float specMask = step(SpecularSize, NdotH) * (1.0 - Roughness);\n    float3 specular = specMask * SpecularIntensity * SpecularColor;\n\n    float fresnel = 1.0 - saturate(dot(WorldNormal, ViewDir));\n    float rim = pow(fresnel, RimPower) * RimIntensity;\n    float3 rimColor = rim * RimColor;\n\n    OutColor = diffuse + specular + rimColor;\n    #endif\n}"
}

