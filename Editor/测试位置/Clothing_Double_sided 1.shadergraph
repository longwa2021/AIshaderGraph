        }
    },
    "m_Slots": [
        {
            "m_Id": "179153a16b864942a99eb98432ec93e5"
        },
        {
            "m_Id": "1021bc3712bd4befbe1312dbbb3cc329"
        },
        {
            "m_Id": "29131dc72020484cafffbfbaca756b5e"
        },
        {
            "m_Id": "c284e85a277c46168f69dc2d372120d0"
        },
        {
            "m_Id": "0e643959c97942f4ac74a67fcf63b133"
        },
        {
            "m_Id": "39f827c5d7a545c0913c5d0d90c01836"
        },
        {
            "m_Id": "fb7d5562f39143d2ba2b41cb80562a3b"
        },
        {
            "m_Id": "6ae64c1e0c96499b85adbdade2ea23e0"
        },
        {
            "m_Id": "3d865dc99a0948e7a6319e5bec956e51"
        },
        {
            "m_Id": "fcfd0f346f944c5cad858f9e3cb9da44"
        },
        {
            "m_Id": "bf8c786417b544b7bc5ece9ed46f1092"
        },
        {
            "m_Id": "645b0a0807d244099ca8124d9519284d"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "UnityChanClothingLighting",
    "m_FunctionSource": "6047667904dc0c94ba96191e1ecf2cc8",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#pragma multi_compile _ _MAIN_LIGHT_SHADOWS\n#pragma multi_compile _ _MAIN_LIGHT_SHADOWS_CASCADE\n#pragma multi_compile _ _ADDITIONAL_LIGHT_SHADOWS\n\n#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid UnityChanClothingLighting_float(\n    float3 WorldPos,\n    float3 WorldNormal,\n    float3 ViewDir,\n    float3 MainLightDir,\n    float3 DiffuseColor,\n    float3 ShadowColor,\n    float3 FalloffColor,\n    float3 RimColor,\n    float SpecularMask,\n    float SpecularPower,\n    float3 EnvMapColor,\n    out float3 OutColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    OutColor = DiffuseColor;\n    #else\n    // --- 诊断开关：取消注释以输出中间结果 ---\n    // OutColor = WorldNormal * 0.5 + 0.5; return;\n    // OutColor = FalloffColor.rrr; return;\n    // OutColor = DiffuseColor; return;\n\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\n    Light mainLight = GetMainLight(shadowCoord);\n    float3 lightColor = mainLight.color;\n    float shadowAtten = mainLight.shadowAttenuation;\n\n    // 确保 falloff 在 0~1 范围内\n    float falloff = saturate(FalloffColor.r);\n    \n    // 基础着色：在阴影色与漫反射色之间插值\n    float3 baseLighting = lerp(ShadowColor, DiffuseColor, falloff);\n    \n    // 主光源照明，并乘以阴影衰减\n    float3 diffuse = baseLighting * lightColor * shadowAtten;\n\n    // 高光\n    float3 halfVec = normalize(ViewDir + MainLightDir);\n    float NdotH = saturate(dot(WorldNormal, halfVec));\n    float spec = pow(NdotH, SpecularPower) * SpecularMask;\n    float3 specular = spec * lightColor * shadowAtten;\n\n    // 合成最终颜色，可选饱和度限制（若场景使用 HDR 则不应 saturate，但此处为防止过曝可临时开启）\n    float3 finalColor = diffuse + specular + RimColor + EnvMapColor;\n    \n    // 若场景非 HDR，可取消下一行注释来钳位颜色\n    // finalColor = saturate(finalColor);\n    \n    OutColor = finalColor;\n    #endif\n}"
}

