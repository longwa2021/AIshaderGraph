        {
            "m_Id": "ff5f36c75c0b4253a35becf03aeddc13"
        },
        {
            "m_Id": "008d9abfd4164a69a5709f6f1dde5be0"
        },
        {
            "m_Id": "a39950ce4c5f48e19229f709108db77c"
        },
        {
            "m_Id": "d68c501c30f74ac9bbac96310763159a"
        },
        {
            "m_Id": "f42e2b2193dd4e78ab1f5dc9ce2e9f23"
        },
        {
            "m_Id": "095ed60da9fd4f36a09df037f97a5b76"
        },
        {
            "m_Id": "b2c7259c2a5f48e38ab43f0d5838f3b0"
        },
        {
            "m_Id": "5a5cd8b8f2e4403fbc32cdd14f58e56f"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "UnityChanBlushLighting",
    "m_FunctionSource": "8dba1315d9f13f547982f4815c39d3c8",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#pragma multi_compile _ _MAIN_LIGHT_SHADOWS\n#pragma multi_compile _ _MAIN_LIGHT_SHADOWS_CASCADE\n#pragma multi_compile _ _ADDITIONAL_LIGHT_SHADOWS\n\n#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid UnityChanBlushLighting_float(\n    float3 WorldPos,\n    float3 WorldNormal,\n    float3 ViewDir,\n    float3 MainLightDir,\n    float3 DiffuseColor,\n    float3 ShadowColor,\n    float3 FalloffColor,\n    float3 RimColor,\n    out float3 OutColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    OutColor = DiffuseColor;\n    #else\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\n    Light mainLight = GetMainLight(shadowCoord);\n    float3 lightColor = mainLight.color;\n    float shadowAtten = mainLight.shadowAttenuation;\n\n    float falloff = FalloffColor.r;\n    float3 baseLighting = lerp(ShadowColor, DiffuseColor, falloff);\n    float3 lit = baseLighting * lightColor * shadowAtten;\n\n    OutColor = lit + RimColor;\n    #endif\n}"
}

