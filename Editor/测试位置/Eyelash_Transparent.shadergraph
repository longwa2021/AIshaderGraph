{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "311f16ca1e6c4872825245308fa4c0a3",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "UnityChanEyelashLighting (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -400.0,
            "y": 0.0,
            "width": 150.0,
            "height": 80.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "49020d9fbd6849af9ad35eb4052ad37e"
        },
        {
            "m_Id": "ad2940e1b4b44baba235a40cd14f71c4"
        },
        {
            "m_Id": "d8e7dedffb3b470a967fc4b7e2906992"
        },
        {
            "m_Id": "5b7c495ce352493cbf983ed9c657da9e"
        },
        {
            "m_Id": "279076c340fb4f5bbff56bf32abfa9df"
        },
        {
            "m_Id": "eff97ff35ac1419fb0acebf6e4e8c71d"
        },
        {
            "m_Id": "8c3fc01795c342589cb7da471a0f00e9"
        },
        {
            "m_Id": "00ac15b165d94b0299abbd7e978fc787"
        },
        {
            "m_Id": "42412f3c55ef4dcab9af76302ba7f38c"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "UnityChanEyelashLighting",
    "m_FunctionSource": "36341c424f4d2784c831abc7b8837f6c",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#pragma multi_compile _ _MAIN_LIGHT_SHADOWS\n#pragma multi_compile _ _MAIN_LIGHT_SHADOWS_CASCADE\n#pragma multi_compile _ _ADDITIONAL_LIGHT_SHADOWS\n\n#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid UnityChanEyelashLighting_float(\n    float3 WorldPos,\n    float3 WorldNormal,\n    float3 ViewDir,\n    float3 MainLightDir,\n    float3 DiffuseColor,\n    float3 ShadowColor,\n    float3 FalloffColor,\n    float3 RimColor,\n    out float3 OutColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    OutColor = DiffuseColor;\n    #else\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\n    Light mainLight = GetMainLight(shadowCoord);\n    float3 lightColor = mainLight.color;\n    float shadowAtten = mainLight.shadowAttenuation;\n\n    float falloff = FalloffColor.r;\n    float3 baseLighting = lerp(ShadowColor, DiffuseColor, falloff);\n    float3 lit = baseLighting * lightColor * shadowAtten;\n\n    OutColor = lit + RimColor;\n    #endif\n}"
}

