    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "9f6db4f0c18f4acda016a5d0dea51aa4",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "UnityChanClothingLighting (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -400.0,
            "y": 0.0,
            "width": 150.0,
            "height": 80.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "158762a4343e45b98f987aa7058b00e0"
        },
        {
            "m_Id": "1231d9c328bb48249903862226ba9e06"
        },
        {
            "m_Id": "b4400ac761f44a4a803bcdae51613524"
        },
        {
            "m_Id": "05ce77cd9d4740a49fc8209dbaaf90fd"
        },
        {
            "m_Id": "f355e0f515a04207b52d402db0438769"
        },
        {
            "m_Id": "5a358f34bfc5482e9ba8507338e38837"
        },
        {
            "m_Id": "3f4bfd3702de4eb4990c876556daf450"
        },
        {
            "m_Id": "ef9cec18009640a4b3310b8d2e3c5226"
        },
        {
            "m_Id": "e0a4131131da43cf88c7804a69aa5777"
        },
        {
            "m_Id": "4b981acbc6df46f69da70d7c17546fa6"
        },
        {
            "m_Id": "6985df32dddb41e3b43de143d6405938"
        },
        {
            "m_Id": "9ee7b07bc8c14c3ea3fe6c323a90812c"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "UnityChanClothingLighting",
    "m_FunctionSource": "af37bb5889110ef46865b36a9a4a9e72",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#pragma multi_compile _ _MAIN_LIGHT_SHADOWS\n#pragma multi_compile _ _MAIN_LIGHT_SHADOWS_CASCADE\n#pragma multi_compile _ _ADDITIONAL_LIGHT_SHADOWS\n\n#if !defined(SHADERGRAPH_PREVIEW)\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n#endif\n\nvoid UnityChanClothingLighting_float(\n    float3 WorldPos,\n    float3 WorldNormal,\n    float3 ViewDir,\n    float3 MainLightDir,\n    float3 DiffuseColor,\n    float3 ShadowColor,\n    float3 FalloffColor,\n    float3 RimColor,\n    float SpecularMask,\n    float SpecularPower,\n    float3 EnvMapColor,\n    out float3 OutColor)\n{\n    #if defined(SHADERGRAPH_PREVIEW)\n    OutColor = DiffuseColor;\n    #else\n    // --- 诊断模式：取消下面注释可将法线可视化，以检查模型切线是否正确 ---\n    // OutColor = WorldNormal * 0.5 + 0.5;\n    // return;\n\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\n    Light mainLight = GetMainLight(shadowCoord);\n    float3 lightColor = mainLight.color;\n    float shadowAtten = mainLight.shadowAttenuation;\n\n    float falloff = FalloffColor.r;\n    float3 baseLighting = lerp(ShadowColor, DiffuseColor, falloff);\n    float3 diffuse = baseLighting * lightColor * shadowAtten;\n\n    float3 halfVec = normalize(ViewDir + MainLightDir);\n    float NdotH = saturate(dot(WorldNormal, halfVec));\n    float spec = pow(NdotH, SpecularPower) * SpecularMask;\n    float3 specular = spec * lightColor * shadowAtten;\n\n    OutColor = diffuse + specular + RimColor + EnvMapColor;\n    #endif\n}"
}

