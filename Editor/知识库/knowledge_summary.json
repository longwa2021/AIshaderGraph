    "blackboard_entry": { "Name": "string", "Type": "Texture2D|Color|Float|Vector2|Vector3|Vector4|Boolean", "DefaultValue": "any", "Mode": "Default|Slider|Integer|Enum", "Range": "[min,max]" }
